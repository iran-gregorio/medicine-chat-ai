# Configurações do Banco de Dados (PostgreSQL + pgvector)
POSTGRES_USER=medicine_user
POSTGRES_PASSWORD=medicine_password
POSTGRES_DB=medicine_chat

# URL de Conexão (Formato SQLAlchemy / asyncpg)
DATABASE_URL=postgresql+asyncpg://medicine_user:medicine_password@localhost:5432/medicine_chat
# Nota: ao rodar via Docker Compose, a URL correta é usada automaticamente pelo ambiente.

# Chaves de API para Integração com IA (LangChain / OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-sua-chave-openrouter-aqui
# OPENAI_API_KEY é opcional ou necessária caso decida usar os embeddings reais da OpenAI.
OPENAI_API_KEY=sk-sua-chave-openai-aqui

# Segurança JWT
# Gere uma chave forte (ex: executando `openssl rand -hex 32` no terminal)
JWT_SECRET_KEY=uma-chave-secreta-muito-segura-e-complexa-aqui
